# ── CultureCompass configuration ───────────────────────────────────────────
# Copy this file to ".env" and fill in your real values.
# Only ONE provider is active at a time — set PROVIDER + its matching API_KEY.

# Which provider to use: openrouter | groq | nvidia | gemini
PROVIDER=openrouter

# Your API key for the chosen provider (paste your real key here in .env)
API_KEY=your-key-here

# Model name for the chosen provider. Leave blank to use the provider default.
# Suggested free/fast options per provider:
#   openrouter : meta-llama/llama-3.3-70b-instruct:free   (or google/gemini-flash-1.5:free)
#   groq       : llama-3.3-70b-versatile                  (very fast)
#   nvidia     : meta/llama-3.3-70b-instruct
#   gemini     : gemini-1.5-flash
MODEL=meta-llama/llama-3.3-70b-instruct:free

# Sampling temperature (0 = focused, 1 = creative). 0.8 is a good default.
TEMPERATURE=0.8

# Port for the local server (optional)
PORT=3000

# Verbose per-request logging (provider, endpoint, timing, tokens, JSON keys,
# and full error bodies). Set to false to quiet it. Default: true.
DEBUG=true

# ── Where to get free keys ──────────────────────────────────────────────────
#   OpenRouter : https://openrouter.ai/keys
#   Groq       : https://console.groq.com/keys
#   NVIDIA     : https://build.nvidia.com  (API key per model page)
#   Gemini     : https://aistudio.google.com/apikey
