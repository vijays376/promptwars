# ── CultureCompass configuration ───────────────────────────────────────────
# Copy this file to ".env" and fill in your real values.
#
# The app uses a PROVIDER FAILOVER CHAIN: it tries the primary PROVIDER first,
# then automatically fails over to any other provider that has a key set.
# So configure as many as you like — more keys = more resilience during the demo.

# ── Primary provider (tried first) ──────────────────────────────────────────
# One of: groq | nvidia | gemini | openrouter
PROVIDER=groq

# Generic key/model for the primary provider (optional if you use the
# per-provider vars below instead).
API_KEY=your-key-here
MODEL=

# ── Per-provider credentials (used for the failover chain) ──────────────────
# Fill in whichever you have. Leave MODEL blank to use that provider's default.

# Groq — fastest / cheapest starting point (https://console.groq.com/keys)
GROQ_API_KEY=your-key-here
GROQ_MODEL=

# NVIDIA — build.nvidia.com; keys start with "nvapi-"
NVIDIA_API_KEY=your-key-here
NVIDIA_MODEL=

# Gemini — Google AI Studio / Vertex OpenAI-compatible endpoint
GEMINI_API_KEY=your-key-here
GEMINI_MODEL=

# OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY=your-key-here
OPENROUTER_MODEL=

# ── Image providers (optional) ──────────────────────────────────────────────
# Photos work with ZERO keys (Openverse + Wikimedia are keyless). Add any of
# these FREE keys to prioritise higher-quality / most-liked images first — they
# form a fallback chain just like the LLM providers.
#   Pixabay  : https://pixabay.com/api/docs/   (sorted by popularity / most-liked)
#   Pexels   : https://www.pexels.com/api/
#   Unsplash : https://unsplash.com/documentation
PIXABAY_KEY=
PEXELS_KEY=
UNSPLASH_ACCESS_KEY=
UNSPLASH_APPLICATION_ID=
UNSPLASH_SECRET_KEY=

# ── Behaviour ───────────────────────────────────────────────────────────────
# Sampling temperature (0 = focused, 1 = creative)
TEMPERATURE=0.8

# Abort a single LLM request after this many ms, then fail over / fall back
LLM_TIMEOUT_MS=15000

# Local server port
PORT=3000

# Verbose per-request logging (provider, endpoint, timing, tokens). false to quiet.
DEBUG=true

# ── Default models per provider (for reference) ─────────────────────────────
#   groq       : llama-3.1-8b-instant
#   nvidia     : meta/llama-3.1-8b-instruct
#   gemini     : gemini-2.5-flash
#   openrouter : google/gemini-2.5-flash
