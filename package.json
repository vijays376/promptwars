{
  "name": "culturecompass",
  "version": "3.0.0",
  "description": "GenAI travel discovery & cultural connection platform — React + Express rebuild.",
  "type": "module",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "node --watch server/index.js",
    "dev:web": "npm --prefix client run dev",
    "build": "npm --prefix client install && npm --prefix client run build",
    "start": "node server/index.js",
    "test": "node --test"
  },
  "engines": { "node": ">=18" },
  "keywords": ["genai", "travel", "culture", "react", "express"],
  "license": "MIT",
  "dependencies": { "express": "^4.21.2" },
  "devDependencies": { "concurrently": "^9.1.2" }
}
